{
  "manifest_version": 3,
  "name": "ZapComment - AI Comment Generator for LinkedIn & X",
  "version": "1.0.0",
  "description": "Generate AI-powered comments for LinkedIn and X using local Ollama models.",

  "permissions": [
    "contextMenus",
    "clipboardWrite",
    "storage",
    "notifications",
    "scripting",
    "activeTab",
    "sidePanel"
  ],

  "host_permissions": [
    "http://localhost:11434/*",
    "https://www.linkedin.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://*.workers.dev/*"
  ],

  "background": {
    "service_worker": "/src/background/service-worker.js",
    "type": "module"
  },

  "action": {
    "default_icon": {
      "16": "/icons/icon16.png",
      "48": "/icons/icon48.png",
      "128": "/icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },

  "icons": {
    "16": "/icons/icon16.png",
    "48": "/icons/icon48.png",
    "128": "/icons/icon128.png"
  },
  "commands": {
  "generate-comment": {
    "suggested_key": {
      "default": "Ctrl+Shift+E",
      "mac": "Command+Shift+E"
    },
    "description": "Generate comment from selected text"
  }
}
}